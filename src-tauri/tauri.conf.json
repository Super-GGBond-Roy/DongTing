{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "语言文化资料库",
  "version": "0.1.0",
  "identifier": "com.dongting.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "侗听",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/resources/corpus/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/corpus/corpus.sqlite": "resources/corpus/corpus.sqlite",
      "resources/corpus/images/*": "resources/corpus/images/",
      "resources/corpus/audio/*": "resources/corpus/audio/"
    }
  }
}
